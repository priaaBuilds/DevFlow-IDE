# Port the Express/Socket.IO server listens on
PORT=4000

# MongoDB connection string. If this is unreachable, the server
# automatically falls back to an in-memory store so collaboration
# still works (just without persistence across restarts).
MONGO_URI=mongodb://localhost:27017/devflow_ide

# The origin of your running frontend (Vite dev server default shown)
CLIENT_ORIGIN=http://localhost:5173
